#!/usr/bin/env bash
set -xeuo pipefail
#MISE depends=["docs:build"]
#MISE dir="docs"
#MISE description="Release documentation site to production or remote"
#MISE tools.wrangler="latest"

wrangler --version

case "${DRY_RUN:-true}" in
true | 1)
	wrangler deploy --dry-run
	;;
false | 0)
	wrangler deploy
	;;
*)
	echo "DRY_RUN must be true, false, 1, or 0" >&2
	exit 1
	;;
esac
