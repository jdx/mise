{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>jdx/renovate-config", "helpers:pinGitHubActionDigests"],
  "automerge": false,
  "asdf": {
    "enabled": false
  },
  "nodenv": {
    "enabled": false
  },
  "packageRules": [
    {
      "description": "AWS SDK requires MSRV 1.91.1, project is 1.88.0. Re-enable when MSRV is bumped.",
      "matchPackageNames": ["aws-config", "aws-sdk-*"],
      "matchManagers": ["cargo"],
      "enabled": false
    },
    {
      "description": "copr image is rebuilt from source on Dockerfile changes; pinning a digest would cause stale image regressions.",
      "matchPackageNames": ["ghcr.io/jdx/mise"],
      "matchCurrentValue": "copr",
      "enabled": false
    },
    {
      "matchPackageNames": ["taiki-e/install-action"],
      "matchManagers": ["github-actions"],
      "enabled": false
    },
    {
      "description": "rattler crates are tightly version-locked across the workspace; bump together.",
      "matchPackageNames": ["/^rattler($|_)/"],
      "matchManagers": ["cargo"],
      "groupName": "rattler"
    }
  ]
}
