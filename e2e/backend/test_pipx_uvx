#!/usr/bin/env bash
require_cmd python3

# Create a system pipx that always fail and push it to the front of PATH
cat >"$HOME/bin/pipx" <<'EOF'
#!/usr/bin/env bash
echo "CALL TO SYSTEM pipx! args: $*" >&2
exit 1
EOF
chmod +x "$HOME"/bin/pipx
export PATH="$HOME/bin:$PATH"

# Just to be sure...
assert_fail "pipx"

# Use precompiled python
export MISE_PYTHON_COMPILE=0
export MISE_PIPX_UVX=1

# Set up a 2-step installation: pipx@1.5.0 > pipx:mkdocs@1.6.0
cat >.mise.toml <<EOF
[tools]
python = "3.12.3"
pipx = "1.5.0"
"github:astral-sh/uv" = "0.5.5"
"pipx:mkdocs" = "1.6.0"
EOF

# Install the tools.
# GitHub-backed downloads occasionally return transient 5xx statuses.
# Retry a few times when that happens to avoid flaky e2e failures.
attempt=1
max_attempts=3
while true; do
	set +e
	install_output="$(mise install 2>&1)"
	install_status=$?
	set -e

	if [[ $install_status -eq 0 ]]; then
		printf '%s\n' "$install_output"
		break
	fi

	if [[ $attempt -ge $max_attempts ]]; then
		printf '%s\n' "$install_output" >&2
		exit "$install_status"
	fi

	if [[ $install_output != *"HTTP status server error (5"* && $install_output != *"HTTP status client error (429"* ]]; then
		printf '%s\n' "$install_output" >&2
		exit "$install_status"
	fi

	printf 'retrying mise install after transient HTTP error (%d/%d)\n' "$attempt" "$max_attempts" >&2
	sleep $((attempt * 2))
	attempt=$((attempt + 1))
done

# Assert that mkdocs 1.6.0 has been installed with pipx
# (mkdocs conveniently returns its installation path in with --version)
assert_contains "mise x -- mkdocs --version" "/mise/installs/pipx-mkdocs/1.6.0/"

assert "mise up --bump python"
assert_contains "mise x -- mkdocs --version" "mkdocs, version 1.6.0"
