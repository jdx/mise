#!/usr/bin/env bash
# npm: tools with semver ranges in mise.toml must lock a concrete version.

export NPM_CONFIG_FUND=false

cat <<EOF >mise.toml
[tools]
node = "lts"
"npm:prettier" = "^3.1.0"
EOF

mise install node
touch mise.lock
mise lock

assert_not_contains "cat mise.lock" 'version = "^3.1.0"'
assert_contains "cat mise.lock" 'version = "3.'
assert_contains "cat mise.lock" 'backend = "npm:prettier"'

# Locked install must reuse the concrete pin for the range request.
LOCKED_VERSION="$(awk '/\[\[tools\."npm:prettier"\]\]/{f=1} f&&/^version = /{print; exit}' mise.lock | sed -n 's/^version = "\(.*\)"/\1/p')"
assert_contains "MISE_LOG_LEVEL=trace mise install --locked --dry-run 2>&1" "[npm:prettier@${LOCKED_VERSION}]"
