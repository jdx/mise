#!/usr/bin/env bash

# Test that --deny-read restricts file reads

# Create a test file in the home dir (outside system paths)
# The test harness sets HOME to a temp dir, so this is safe
echo "secret_data" >"$HOME/.mise_sandbox_read_test"
trap 'rm -f "$HOME/.mise_sandbox_read_test"' EXIT

# Without sandbox, file is readable
assert "mise x -- cat $HOME/.mise_sandbox_read_test" "secret_data"

# With --deny-read, reading should fail
assert_fail "mise x --deny-read -- cat $HOME/.mise_sandbox_read_test 2>/dev/null"

# With --allow-read for HOME, it should work
assert "mise x --allow-read=$HOME -- cat $HOME/.mise_sandbox_read_test" "secret_data"
