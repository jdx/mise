#!/usr/bin/env bash
set -x

mise use sops age
age="$(mise x -- age-keygen 2>&1)"
age_pub="$(echo "$age" | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
MISE_SOPS_AGE_KEY="$(echo "$age" | grep "AGE-SECRET-KEY")"
export MISE_SOPS_AGE_KEY

# json
echo '{ "SECRET": "mysecret" }' >.env.json
mise x -- sops encrypt -i --age "$age_pub" .env.json
assert "mise set _.file=.env.json"
assert_contains "mise env" "export SECRET=mysecret"

# yaml
age_output="$(mise x -- age-keygen -o ~/age.txt 2>&1)"
age_pub="$(echo "$age_output" | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
mise settings set sops.age_key_file "~/age.txt"
echo 'SECRET: mysecret' >.env.yaml
mise x -- sops encrypt -i --age "$age_pub" .env.yaml
export MISE_SOPS_AGE_KEY=
assert "mise set _.file=.env.yaml"
assert_contains "mise env" "export SECRET=mysecret"

# sops
mise settings set sops.rops 0
assert_contains "mise env" "export SECRET=mysecret"

# Test standard SOPS_AGE_KEY_FILE environment variable
sops_age_file="$HOME/sops_age.txt"
age_output="$(mise x -- age-keygen -o "$sops_age_file" 2>&1)"
age_pub="$(echo "$age_output" | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
SOPS_AGE_KEY_FILE="$sops_age_file"
export SOPS_AGE_KEY_FILE
rm -f .env.sops_file.yaml
echo 'SECRET: standard_sops_file' >.env.sops_file.yaml
mise x -- sops encrypt -i --age "$age_pub" .env.sops_file.yaml
unset MISE_SOPS_AGE_KEY
mise settings unset sops.age_key_file
assert "mise set _.file=.env.sops_file.yaml"
assert_contains "mise env" "export SECRET=standard_sops_file"

# Test standard SOPS_AGE_KEY environment variable (direct key content)
age_output="$(mise x -- age-keygen 2>&1)"
age_pub="$(echo "$age_output" | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
SOPS_AGE_KEY="$(echo "$age_output" | grep "AGE-SECRET-KEY")"
export SOPS_AGE_KEY
unset SOPS_AGE_KEY_FILE
rm -f .env.sops_key.yaml
echo 'SECRET: standard_sops_key' >.env.sops_key.yaml
mise x -- sops encrypt -i --age "$age_pub" .env.sops_key.yaml
assert "mise set _.file=.env.sops_key.yaml"
assert_contains "mise env" "export SECRET=standard_sops_key"

# Test precedence: SOPS_AGE_KEY_FILE should take precedence over MISE_SOPS_AGE_KEY_FILE
precedence_std_file="$HOME/precedence_standard.txt"
precedence_mise_file="$HOME/precedence_mise.txt"
age_pub1="$(mise x -- age-keygen -o "$precedence_std_file" 2>&1 | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
age_pub2="$(mise x -- age-keygen -o "$precedence_mise_file" 2>&1 | grep -E "(Public key:|# public key:)" | awk '{print $(NF)}')"
SOPS_AGE_KEY_FILE="$precedence_std_file"
export SOPS_AGE_KEY_FILE
mise settings set sops.age_key_file "$precedence_mise_file"
rm -f .env.precedence.yaml
echo 'SECRET: precedence_test' >.env.precedence.yaml
mise x -- sops encrypt -i --age "$age_pub1" .env.precedence.yaml
unset SOPS_AGE_KEY
assert "mise set _.file=.env.precedence.yaml"
assert_contains "mise env" "export SECRET=precedence_test"
