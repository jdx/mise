#!/usr/bin/env bash
set -euo pipefail

mise use sops age python

age_output="$(mise x -- age-keygen 2>&1)"
age_pub="$(echo "$age_output" | grep -E "(Public key:|# public key:)" | head -1 | awk '{print $(NF)}')"
SOPS_AGE_KEY="$(echo "$age_output" | grep "AGE-SECRET-KEY")"

mkdir -p ~/.config/mise/sops/age
echo "$SOPS_AGE_KEY" >~/.config/mise/sops/age/test-key.txt

echo '{ "SECRET": "mysecret" }' >.env.json
mise x -- sops encrypt -i --age "$age_pub" .env.json

cat >.mise.toml <<'TOML'
[tools]
python = "3.12"

[env]
_.python.venv = {path = ".venv", create = true}
SOPS_KEY_FILE = "{{env.HOME}}/.config/mise/sops/age/test-key.txt"
_.file = ".env.json"

[settings]
sops.age_key_file = "{{env.SOPS_KEY_FILE}}"
TOML

assert_fail "mise env" "Split these entries into ordered"

cat >.mise.toml <<'TOML'
[tools]
python = "3.12"

[[env]]
_.python.venv = {path = ".venv", create = true}

[[env]]
SOPS_KEY_FILE = "{{env.HOME}}/.config/mise/sops/age/test-key.txt"

[[env]]
_.file = ".env.json"

[settings]
sops.age_key_file = "{{env.SOPS_KEY_FILE}}"
TOML

assert_contains "mise env" "export SECRET=mysecret"

cat >.mise.toml <<'TOML'
[env]
SOPS_KEY_FILE = "{{env.HOME}}/.config/mise/sops/age/test-key.txt"
_.file = ".env.json"

[settings]
sops.age_key_file = "{{env.SOPS_KEY_FILE}}"
TOML

assert_contains "mise env" "export SECRET=mysecret"
