run_in_pty() {
	python3 - "$@" <<'PY'
import os
import pty
import select
import signal
import subprocess
import sys
import time

cmd = sys.argv[1:]
master_fd, slave_fd = pty.openpty()
proc = subprocess.Popen(
    cmd,
    stdin=slave_fd,
    stdout=slave_fd,
    stderr=slave_fd,
    close_fds=True,
)
os.close(slave_fd)

input_data = os.environ.get("PTY_INPUT", "")
signal_name = os.environ.get("PTY_SIGNAL", "")
signal_after = float(os.environ.get("PTY_SIGNAL_AFTER", "0"))
timeout_s = float(os.environ.get("PTY_TIMEOUT", "20"))

if input_data:
    time.sleep(0.10)
    os.write(master_fd, input_data.encode())

signal_sent = False
start = time.time()
output = bytearray()
while True:
    elapsed = time.time() - start
    if signal_name and not signal_sent and elapsed >= signal_after:
        sig = getattr(signal, signal_name)
        os.kill(proc.pid, sig)
        signal_sent = True
    if elapsed > timeout_s:
        proc.kill()
        os.close(master_fd)
        sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
        sys.stderr.write(f"\nPTY timeout after {timeout_s}s\n")
        sys.exit(124)

    ready, _, _ = select.select([master_fd], [], [], 0.2)
    if ready:
        try:
            chunk = os.read(master_fd, 4096)
        except OSError:
            break
        if not chunk:
            break
        output.extend(chunk)

    if proc.poll() is not None and not ready:
        break

os.close(master_fd)
status = proc.wait()
sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
sys.exit(status)
PY
}
export -f run_in_pty

assert_probe_ok() {
	assert "mise run probe" "probe-ok"
}

# Matrix: F01/F06/F10 + O2/O3/O4 (C12)
cat <<'EOF' >mise.toml
[tasks.int-ok]
interactive = true
run = '''
printf "ok> "
read value
echo "ok:$value"
'''

[tasks.probe]
run = "echo probe-ok"
EOF
out="$(PTY_INPUT=$'v\n' run_in_pty mise run int-ok)"
if [[ $out != *"ok:v"* ]]; then
	fail "interactive success path did not receive input"
fi
assert_probe_ok

