#!/usr/bin/env bash

# Stress: two concurrent mixed runtime parents each inject an interactive child.
# Expectation: no deadlock/livelock; both interactive children run and parents resume.
# Matrix refs: B01/B05/B07/B08/B09/B10/B12/B13 + O1/O6/O7 (C1/C10/C11/C13)
# Applicability: dynamic
set -euo pipefail
require_cmd python3

run_in_pty_with_input() {
	python3 - "$@" <<'PY'
import os
import pty
import select
import subprocess
import sys
import time

cmd = sys.argv[1:]
master_fd, slave_fd = pty.openpty()
proc = subprocess.Popen(
    cmd,
    stdin=slave_fd,
    stdout=slave_fd,
    stderr=slave_fd,
    close_fds=True,
)
os.close(slave_fd)

input_data = os.environ.get("PTY_INPUT", "")
if input_data:
    time.sleep(0.10)
    os.write(master_fd, input_data.encode())

timeout_s = float(os.environ.get("PTY_TIMEOUT", "20"))
start = time.time()
output = bytearray()
while True:
    if time.time() - start > timeout_s:
        proc.kill()
        os.close(master_fd)
        sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
        sys.stderr.write(f"\nPTY timeout after {timeout_s}s\n")
        sys.exit(124)
    ready, _, _ = select.select([master_fd], [], [], 0.2)
    if ready:
        try:
            chunk = os.read(master_fd, 4096)
        except OSError:
            break
        if not chunk:
            break
        output.extend(chunk)
    if proc.poll() is not None and not ready:
        break

os.close(master_fd)
status = proc.wait()
sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
sys.exit(status)
PY
}
export -f run_in_pty_with_input

cat <<'TOML' >mise.toml
[tasks.ia]
interactive = true
run = '''
printf "ia> "
read value
echo "ia:$value"
'''

[tasks.ib]
interactive = true
run = '''
printf "ib> "
read value
echo "ib:$value"
'''

[tasks.qa_a]
run = [
  "echo qa_a:pre",
  { task = "ia" },
  "echo qa_a:post"
]

[tasks.qa_b]
run = [
  "echo qa_b:pre",
  { task = "ib" },
  "echo qa_b:post"
]

[tasks.noise]
run = "echo noise"
TOML

for _ in $(seq 1 60); do
	set +e
	out="$(PTY_INPUT=$'x\ny\n' PTY_TIMEOUT=10 run_in_pty_with_input mise run --jobs=2 qa_a ::: qa_b ::: noise 2>&1)"
	status=$?
	set -e
	if [[ $status -eq 124 ]]; then
		fail "deadlock detected under dual mixed-parent contention: $out"
	fi
	if [[ $status -ne 0 ]]; then
		fail "expected successful run under dual mixed-parent contention (status=$status): $out"
	fi
	if [[ $out != *"ia:"* ]] || [[ $out != *"ib:"* ]]; then
		fail "expected both interactive children to consume input"
	fi
	if [[ $out != *"qa_a:post"* ]] || [[ $out != *"qa_b:post"* ]]; then
		fail "expected both mixed parents to resume after injected interactive child"
	fi
done
