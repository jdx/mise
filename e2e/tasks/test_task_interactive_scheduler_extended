set -euo pipefail
require_cmd python3

run_in_pty_with_input() {
	python3 - "$@" <<'PY'
import os
import pty
import select
import subprocess
import sys
import time

cmd = sys.argv[1:]
master_fd, slave_fd = pty.openpty()
proc = subprocess.Popen(
    cmd,
    stdin=slave_fd,
    stdout=slave_fd,
    stderr=slave_fd,
    close_fds=True,
)
os.close(slave_fd)

input_data = os.environ.get("PTY_INPUT", "")
if input_data:
    time.sleep(0.10)
    os.write(master_fd, input_data.encode())

timeout_s = float(os.environ.get("PTY_TIMEOUT", "20"))
start = time.time()
output = bytearray()
while True:
    if time.time() - start > timeout_s:
        proc.kill()
        os.close(master_fd)
        sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
        sys.stderr.write(f"\nPTY timeout after {timeout_s}s\n")
        sys.exit(124)
    ready, _, _ = select.select([master_fd], [], [], 0.2)
    if ready:
        try:
            chunk = os.read(master_fd, 4096)
        except OSError:
            break
        if not chunk:
            break
        output.extend(chunk)
    if proc.poll() is not None and not ready:
        break

os.close(master_fd)
status = proc.wait()
sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
sys.exit(status)
PY
}
export -f run_in_pty_with_input

assert_order() {
	local file="$1"
	local before="$2"
	local after="$3"
	local before_line
	local after_line
	before_line="$(grep -n "^${before}$" "$file" | head -n1 | cut -d: -f1)"
	after_line="$(grep -n "^${after}$" "$file" | head -n1 | cut -d: -f1)"
	if [[ -z $before_line || -z $after_line || $before_line -ge $after_line ]]; then
		echo "Order assertion failed: '$before' must appear before '$after'"
		cat "$file"
		exit 1
	fi
}

trace=$(mktemp)
lock_dir="$(mktemp -u)"
trap 'rm -f "$trace"; rmdir "$lock_dir" 2>/dev/null || true' EXIT

# Matrix: B02/B03 + O1 (C1/C3/C4/C11)
cat <<'EOF' >mise.toml
[tasks.dep-a]
run = '''
if [ -d "$LOCK_DIR" ]; then echo "overlap dep-a" >> "$TRACE_FILE"; fi
echo "dep-a:start" >> "$TRACE_FILE"
sleep 0.05
echo "dep-a:end" >> "$TRACE_FILE"
'''

[tasks.dep-b]
run = '''
if [ -d "$LOCK_DIR" ]; then echo "overlap dep-b" >> "$TRACE_FILE"; fi
echo "dep-b:start" >> "$TRACE_FILE"
sleep 0.05
echo "dep-b:end" >> "$TRACE_FILE"
'''

[tasks.post]
run = '''
if [ -d "$LOCK_DIR" ]; then echo "overlap post" >> "$TRACE_FILE"; fi
echo "post:start" >> "$TRACE_FILE"
sleep 0.02
echo "post:end" >> "$TRACE_FILE"
'''

[tasks.main]
depends = ["dep-a", "dep-b"]
depends_post = ["post"]
interactive = true
run = '''
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  echo "overlap main" >> "$TRACE_FILE"
  exit 90
fi
echo "main:start" >> "$TRACE_FILE"
printf "main> "
read value
echo "main:$value"
sleep 0.08
echo "main:end" >> "$TRACE_FILE"
rmdir "$LOCK_DIR"
'''
EOF

: >"$trace"
out="$(
	TRACE_FILE="$trace" LOCK_DIR="$lock_dir" PTY_INPUT=$'hello\n' \
		run_in_pty_with_input mise run main
)"
if [[ $out != *"main:hello"* ]]; then
	fail "expected interactive input to reach main task"
fi
assert_order "$trace" "dep-a:end" "main:start"
assert_order "$trace" "dep-b:end" "main:start"
assert_order "$trace" "main:end" "post:start"
if grep -q '^overlap ' "$trace"; then
	fail "overlap detected around interactive barrier"
fi

