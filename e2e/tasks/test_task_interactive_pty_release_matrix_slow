#!/usr/bin/env bash
set -euo pipefail

require_cmd expect

run_expect_with_input() {
	local cmd="$1"
	local prompt_re="$2"
	local input="$3"
	expect "$TEST_ROOT/helpers/scripts/interactive_expect.tcl" with-input "$cmd" "$prompt_re" "$input"
}

run_expect_ctrl_c_after() {
	local cmd="$1"
	local pattern="$2"
	expect "$TEST_ROOT/helpers/scripts/interactive_expect.tcl" ctrl-c-after "$cmd" "$pattern"
}

run_expect_wait() {
	local cmd="$1"
	expect "$TEST_ROOT/helpers/scripts/interactive_expect.tcl" wait-eof "$cmd"
}

# MatrixRef: F11,F03,F08,G03 / C12,C13
cat <<'EOF' >mise.toml
[tasks.ask_timeout]
interactive = true
run = 'sleep 5'

[tasks.ask_ok]
interactive = true
run = 'printf "OK_PROMPT>" >&2; read -r line; echo "OK:$line"'
EOF
out="$(run_expect_wait "mise run --timeout=1s ask_timeout" 2>&1)" && exit_code=0 || exit_code=$?
[[ $exit_code -ne 0 ]] || fail "timeout scenario expected non-zero exit"
[[ $out == *"timed out"* ]] || fail "timeout scenario missing timeout message: $out"

out="$(run_expect_with_input "mise run ask_ok" "OK_PROMPT>" "after-timeout" 2>&1)" || {
	echo "$out"
	fail "run after timeout should not be blocked"
}
[[ $out == *"OK:after-timeout"* ]] || fail "post-timeout interactive run failed: $out"

