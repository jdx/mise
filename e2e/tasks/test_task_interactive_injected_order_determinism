#!/usr/bin/env bash

# Regression: interactive order/routing must remain deterministic across repeated runs
# when two interactive tasks become ready under concurrent injected subgraphs.
# Matrix refs: B05/B06/B09/B10 + O5/O6 (C10/C11)
# Applicability: dynamic
set -euo pipefail
require_cmd python3

cat <<'TOML' >mise.toml
[tasks.ia]
interactive = true
run = '''
printf "ia> "
read value
echo "ia:$value"
'''

[tasks.ib]
interactive = true
run = '''
printf "ib> "
read value
echo "ib:$value"
'''

[tasks.w3]
run = 'echo w3'

[tasks.w4]
run = 'echo w4'

[tasks.sub-a]
run = [{ task = "ia" }, { task = "w3" }]

[tasks.sub-b]
run = [{ task = "ib" }, { task = "w4" }]
TOML

set +e
report="$(
	python3 - <<'PY'
import os
import pty
import select
import subprocess
import sys
import time

cmd = ["mise", "run", "--jobs=32", "sub-a", ":::", "sub-b", ":::", "w3", ":::", "w4"]
loops = int(os.environ.get("ORDER_LOOPS", "140"))
timeout_s = float(os.environ.get("PTY_TIMEOUT", "10"))

saw_ia_first = False
saw_ib_first = False
samples = []

for i in range(1, loops + 1):
    master_fd, slave_fd = pty.openpty()
    proc = subprocess.Popen(
        cmd,
        stdin=slave_fd,
        stdout=slave_fd,
        stderr=slave_fd,
        close_fds=True,
    )
    os.close(slave_fd)
    time.sleep(0.08)
    os.write(master_fd, b"sa\nsb\n")

    output = bytearray()
    start = time.time()
    timed_out = False
    while True:
        if time.time() - start > timeout_s:
            proc.kill()
            timed_out = True
            break
        ready, _, _ = select.select([master_fd], [], [], 0.2)
        if ready:
            try:
                chunk = os.read(master_fd, 4096)
            except OSError:
                break
            if not chunk:
                break
            output.extend(chunk)
        if proc.poll() is not None and not ready:
            break

    os.close(master_fd)
    status = proc.wait()
    out = bytes(output).replace(b"\r\n", b"\n").decode(errors="replace")

    if timed_out:
        print(f"FAIL timeout at iteration {i}")
        print(out)
        sys.exit(1)
    if status != 0:
        print(f"FAIL non-zero status at iteration {i}: {status}")
        print(out)
        sys.exit(1)

    ia_sa = "ia:sa" in out
    ia_sb = "ia:sb" in out
    ib_sa = "ib:sa" in out
    ib_sb = "ib:sb" in out

    if ia_sa and ib_sb:
        saw_ia_first = True
        samples.append((i, "ia_first"))
    elif ia_sb and ib_sa:
        saw_ib_first = True
        samples.append((i, "ib_first"))
    else:
        print(f"FAIL unexpected interactive routing at iteration {i}")
        print(out)
        sys.exit(1)

    if saw_ia_first and saw_ib_first:
        print("FAIL nondeterministic interactive routing/order detected")
        print("samples:", samples[:10])
        sys.exit(1)

if saw_ib_first:
    print("FAIL deterministic order is stable but opposite to expected lexicographic tie-break")
    print("samples:", samples[:10])
    sys.exit(1)

print("OK deterministic routing/order")
PY
)"
status=$?
set -e

if [[ $status -ne 0 ]]; then
	fail "$report"
fi
