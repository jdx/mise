#!/usr/bin/env bash

# Regression: Ctrl-C must abort injected interactive wait loops (no SIGTERM required).
# Contract refs: C13 (no deadlock on signal), C12 (clean release)
# Applicability: dynamic
set -euo pipefail
if ! type -p python3 >/dev/null; then
	echo "python3 is required for this test"
	exit 2
fi

run_in_pty_with_signal() {
	python3 - "$@" <<'PY'
import os
import pty
import select
import signal
import subprocess
import sys
import time

cmd = sys.argv[1:]
master_fd, slave_fd = pty.openpty()
proc = subprocess.Popen(
    cmd,
    stdin=slave_fd,
    stdout=slave_fd,
    stderr=slave_fd,
    close_fds=True,
)
os.close(slave_fd)

signal_name = os.environ.get("PTY_SIGNAL", "")
signal_after = float(os.environ.get("PTY_SIGNAL_AFTER", "0"))
timeout_s = float(os.environ.get("PTY_TIMEOUT", "20"))

signal_sent = False
start = time.time()
output = bytearray()
while True:
    elapsed = time.time() - start
    if signal_name and not signal_sent and elapsed >= signal_after:
        os.kill(proc.pid, getattr(signal, signal_name))
        signal_sent = True

    if elapsed > timeout_s:
        proc.kill()
        os.close(master_fd)
        sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
        sys.stderr.write(f"\nPTY timeout after {timeout_s}s\n")
        sys.exit(124)

    ready, _, _ = select.select([master_fd], [], [], 0.2)
    if ready:
        try:
            chunk = os.read(master_fd, 4096)
        except OSError:
            break
        if not chunk:
            break
        output.extend(chunk)

    if proc.poll() is not None and not ready:
        break

os.close(master_fd)
status = proc.wait()
sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
sys.exit(status)
PY
}
export -f run_in_pty_with_signal

cat <<'TOML' >mise.toml
[tasks.setup]
run = "echo setup"

[tasks.smoke_interactive]
interactive = true
run = 'printf "PROMPT>" >&2; read -r x; echo "SMOKE:$x"'

[tasks.qa_suite]
run = [
  "echo QA_PRE",
  { task = "setup" },
  { task = "smoke_interactive" },
  "echo QA_POST"
]

[tasks.release]
run = [{ task = "qa_suite" }]

[tasks.probe]
run = "echo probe-ok"
TOML

set +e
out="$(PTY_SIGNAL=SIGINT PTY_SIGNAL_AFTER=0.6 PTY_TIMEOUT=10 run_in_pty_with_signal mise run release 2>&1)"
status=$?
set -e

if [[ $status -eq 124 ]]; then
	echo "expected Ctrl-C to abort run; command hung until timeout"
	echo "$out"
	exit 1
fi

if [[ $status -eq 0 ]]; then
	echo "expected non-zero status after Ctrl-C"
	echo "$out"
	exit 1
fi

probe_out="$(mise run probe 2>&1)"
if [[ $probe_out != *"probe-ok"* ]]; then
	echo "probe task did not run cleanly after Ctrl-C scenario"
	echo "$probe_out"
	exit 1
fi
