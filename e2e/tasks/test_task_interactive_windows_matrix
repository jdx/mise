#!/usr/bin/env bash

# Matrix refs:
# - W01/W02/W03/W04/W05/W06
# - Contract: C2/C6/C12/C13/C16
# Applicability: common

set -euo pipefail

case "$(uname -s)" in
MINGW* | MSYS* | CYGWIN*) ;;
*)
	echo "Skipping Windows interactive matrix on non-Windows platform"
	exit 0
	;;
esac

require_cmd python3

run_in_pty_with_input() {
	python3 - "$@" <<'PY'
import os
import pty
import select
import signal
import subprocess
import sys
import time

cmd = sys.argv[1:]
master_fd, slave_fd = pty.openpty()
proc = subprocess.Popen(cmd, stdin=slave_fd, stdout=slave_fd, stderr=slave_fd, close_fds=True)
os.close(slave_fd)

input_data = os.environ.get("PTY_INPUT", "")
if input_data:
    time.sleep(0.1)
    os.write(master_fd, input_data.encode())

signal_name = os.environ.get("PTY_SIGNAL", "")
signal_after = float(os.environ.get("PTY_SIGNAL_AFTER", "0"))
signal_sent = False
timeout_s = float(os.environ.get("PTY_TIMEOUT", "20"))
start = time.time()
output = bytearray()
while True:
    elapsed = time.time() - start
    if signal_name and not signal_sent and elapsed >= signal_after:
        os.kill(proc.pid, getattr(signal, signal_name))
        signal_sent = True
    if elapsed > timeout_s:
        proc.kill()
        os.close(master_fd)
        sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
        sys.stderr.write(f"\nPTY timeout after {timeout_s}s\n")
        sys.exit(124)
    ready, _, _ = select.select([master_fd], [], [], 0.2)
    if ready:
        try:
            chunk = os.read(master_fd, 4096)
        except OSError:
            break
        if not chunk:
            break
        output.extend(chunk)
    if proc.poll() is not None and not ready:
        break
os.close(master_fd)
status = proc.wait()
sys.stdout.buffer.write(bytes(output).replace(b"\r\n", b"\n"))
sys.exit(status)
PY
}
export -f run_in_pty_with_input

cat <<'EOF' >mise.toml
[tasks.win-int]
interactive = true
run_windows = '''
echo win-int-start
set /p value=
echo win-int:%value%
'''

[tasks.win-path]
run_windows = "echo C:\\Windows\\System32"

[tasks.win-int-long]
interactive = true
run_windows = '''
echo win-int-long-start
timeout /t 5 /nobreak >nul
echo win-int-long-end
'''

[tasks.probe]
run_windows = "echo probe-ok"
EOF

# Matrix: W01 (C2)
out="$(PTY_INPUT=$'abc\n' run_in_pty_with_input mise run win-int)"
if [[ $out != *"win-int:abc"* ]]; then
	echo "$out"
	fail "Windows interactive run_windows task did not receive input"
fi

# Matrix: W04 (C2/C6)
out="$(PTY_INPUT=$'crlf-test\r\n' run_in_pty_with_input mise run win-int)"
if [[ $out != *"win-int:crlf-test"* ]]; then
	fail "CRLF/LF handling failed in Windows interactive session"
fi

# Matrix: W06 (C16)
assert_contains "mise run win-path" 'C:\Windows\System32'

# Matrix: W05 (C12/C13)
set +e
out="$(PTY_SIGNAL=SIGINT PTY_SIGNAL_AFTER=0.40 PTY_TIMEOUT=12 run_in_pty_with_input mise run win-int-long 2>&1)"
status=$?
set -e
if [[ $status -eq 0 ]]; then
	fail "expected Ctrl-C interruption for interactive Windows task"
fi
assert_contains "mise run probe" "probe-ok"

# Matrix: W02/W03/W05 are shell/console-specific and environment-dependent.
# Keep explicit smoke assertions when shells are available.
if command -v cmd >/dev/null 2>&1; then
	# Matrix: W02 (C2)
	assert_contains 'cmd /c "echo cmd-ok"' "cmd-ok"
fi
if command -v pwsh >/dev/null 2>&1; then
	# Matrix: W03 (C2)
	assert_contains "pwsh -NoProfile -Command \"Write-Output 'pwsh-ok'\"" "pwsh-ok"
fi
