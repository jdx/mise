#!/usr/bin/env bash

# Test that task_config.includes is additive and hierarchical

# --- Root Config ---
cat <<'INNER_EOF' >mise.toml
[task_config]
includes = ["./tasks.toml", "./tasks/"]
INNER_EOF

cat <<'INNER_EOF' >tasks.toml
[root-file-task]
run = 'echo "root file task"'
INNER_EOF

mkdir -p tasks
cat <<'INNER_EOF' >tasks/root-dir-task.sh
#!/usr/bin/env bash
echo "root dir task"
INNER_EOF
chmod +x tasks/root-dir-task.sh

mkdir -p mise-tasks
cat <<'INNER_EOF' >mise-tasks/root-default-dir-task.sh
#!/usr/bin/env bash
echo "root default dir task"
INNER_EOF
chmod +x mise-tasks/root-default-dir-task.sh

# --- Subdir Config ---
mkdir -p subdir/tasks subdir/local-tasks subdir/mise-tasks

cat <<'INNER_EOF' >subdir/mise.toml
[task_config]
includes = ["./tasks.toml", "./tasks/"]
INNER_EOF

cat <<'INNER_EOF' >subdir/tasks.toml
[sub-file-task]
run = 'echo "sub file task"'
INNER_EOF

cat <<'INNER_EOF' >subdir/tasks/sub-dir-task.sh
#!/usr/bin/env bash
echo "sub dir task"
INNER_EOF
chmod +x subdir/tasks/sub-dir-task.sh

cat <<'INNER_EOF' >subdir/mise-tasks/sub-default-dir-task.sh
#!/usr/bin/env bash
echo "sub default dir task"
INNER_EOF
chmod +x subdir/mise-tasks/sub-default-dir-task.sh

cat <<'INNER_EOF' >subdir/mise.local.toml
[task_config]
includes = ["./tasks.local.toml", "./local-tasks/"]
INNER_EOF

cat <<'INNER_EOF' >subdir/tasks.local.toml
[local-file-task]
run = 'echo "local file task"'
INNER_EOF

cat <<'INNER_EOF' >subdir/local-tasks/local-dir-task.sh
#!/usr/bin/env bash
echo "local dir task"
INNER_EOF
chmod +x subdir/local-tasks/local-dir-task.sh

# --- Assertions ---

# Assertions from root
assert_contains "mise tasks ls" "root-file-task"
assert_contains "mise tasks ls" "root-dir-task"
assert_contains "mise tasks ls" "root-default-dir-task"
assert_not_contains "mise tasks ls" "sub-file-task"
assert_not_contains "mise tasks ls" "sub-dir-task"
assert_not_contains "mise tasks ls" "local-file-task"
assert_not_contains "mise tasks ls" "local-dir-task"
assert_not_contains "mise tasks ls" "sub-default-dir-task"

assert_contains "mise run root-file-task" "root file task"
assert_contains "mise run root-dir-task" "root dir task"
assert_contains "mise run root-default-dir-task" "root default dir task"

# Assertions from subdir
cd subdir

assert_contains "mise tasks ls" "root-file-task"
assert_contains "mise tasks ls" "root-dir-task"
assert_contains "mise tasks ls" "root-default-dir-task"
assert_contains "mise tasks ls" "sub-file-task"
assert_contains "mise tasks ls" "sub-dir-task"
assert_contains "mise tasks ls" "local-file-task"
assert_contains "mise tasks ls" "local-dir-task"
assert_contains "mise tasks ls" "sub-default-dir-task"

# Verify running tasks
assert_contains "mise run root-file-task" "root file task"
assert_contains "mise run root-dir-task" "root dir task"
assert_contains "mise run root-default-dir-task" "root default dir task"
assert_contains "mise run sub-file-task" "sub file task"
assert_contains "mise run sub-dir-task" "sub dir task"
assert_contains "mise run local-file-task" "local file task"
assert_contains "mise run local-dir-task" "local dir task"
assert_contains "mise run sub-default-dir-task" "sub default dir task"
