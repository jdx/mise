#!/usr/bin/env bash

# MatrixRef: V02 / C15
mkdir -p mise-tasks && echo "" >mise-tasks/build.sh && chmod +x mise-tasks/build.sh
assert "mise tasks info build" 'Task: build
Description:
Source: ~/workdir/mise-tasks/build.sh:1
File: ~/workdir/mise-tasks/build.sh

Usage Spec:
  name build
  bin build'

assert_contains "mise tasks info build.sh --json" '"name": "build"'

assert_json_partial_object "mise tasks info build --json" "name,source,description" '{
  "name": "build",
  "source": "'"$PWD"'/mise-tasks/build.sh",
  "description": ""
}'

mise tasks add lint --depends "build -v" -- 'echo "linting!"'
assert_contains "mise tasks info lint --json" '"name": "lint"'
assert_contains "mise tasks info lint --json" '"interactive": false'
assert_contains "mise tasks info lint --json" "\"source\": \"$(pwd)/mise.toml\""
assert_contains "mise tasks info lint --json" '"source_location": "~/workdir/mise.toml:1"'
assert_contains "mise tasks info lint --json" '"declaration": {'
assert_contains "mise tasks info lint --json" '"before_help_long": "- Depends: build -v"'
