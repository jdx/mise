#!/usr/bin/env bash

export MISE_TRUSTED_CONFIG_PATHS=""
unset CI GITHUB_ACTIONS GITHUB_ACTION 2>/dev/null || true

mkdir -p project
cat <<'EOF' >project/mise.toml
[hooks]
enter = 'echo HOOK-ENTER'
EOF

cd project || exit 1
assert_contains "mise trust 2>&1" "HOOK-ENTER"
assert_not_contains "mise trust 2>&1" "HOOK-ENTER"

cd .. || exit 1
mkdir -p other
cat <<'EOF' >other/mise.toml
[hooks]
enter = 'echo OTHER-ENTER'
EOF

assert_not_contains "mise trust other/mise.toml 2>&1" "OTHER-ENTER"

mkdir -p parent/child
cat <<'EOF' >parent/mise.toml
[hooks]
enter = 'echo PARENT-ENTER'
EOF
cat <<'EOF' >parent/child/mise.toml
[hooks]
enter = 'echo CHILD-ENTER'
EOF

cd parent || exit 1
assert_contains "mise trust 2>&1" "PARENT-ENTER"

cd child || exit 1
child_trust_output="$(mise trust 2>&1)"
[[ $child_trust_output == *"CHILD-ENTER"* ]] || fail "expected child enter hook to run"
[[ $child_trust_output != *"PARENT-ENTER"* ]] || fail "parent enter hook should not re-run"

cd ../.. || exit 1
mkdir -p guarded/child
cat <<'EOF' >guarded/mise.toml
[hooks]
enter = 'echo GUARDED-PARENT-ENTER'
EOF
cat <<'EOF' >guarded/child/mise.toml
[hooks]
enter = 'echo GUARDED-CHILD-ENTER'
EOF

cd guarded/child || exit 1
guarded_child_output="$(mise trust mise.toml 2>&1)"
[[ $guarded_child_output != *"GUARDED-PARENT-ENTER"* ]] || fail "parent hook should not run with untrusted parent"
[[ $guarded_child_output != *"GUARDED-CHILD-ENTER"* ]] || fail "child hook should wait for untrusted parent"

cd ../.. || exit 1
mkdir -p trust_all/child
cat <<'EOF' >trust_all/mise.toml
[hooks]
enter = 'echo ALL-PARENT-ENTER'
EOF
cat <<'EOF' >trust_all/child/mise.toml
[hooks]
enter = 'echo ALL-CHILD-ENTER'
EOF

cd trust_all/child || exit 1
trust_all_output="$(mise trust --all 2>&1)"
[[ $trust_all_output == *"ALL-PARENT-ENTER"* ]] || fail "expected parent enter hook with --all"
[[ $trust_all_output == *"ALL-CHILD-ENTER"* ]] || fail "expected child enter hook with --all"
