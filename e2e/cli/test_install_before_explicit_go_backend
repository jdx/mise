#!/usr/bin/env bash
set -euo pipefail

export GOPROXY="https://proxy.golang.org,direct"

cat <<'EOF' >mise.toml
[settings]
install_before = "2100-01-01"

[tools]
'go:github.com/roborev-dev/roborev/cmd/roborev' = { version = "latest", install_before = "2026-04-07" }
EOF

first_output=$(mise install --dry-run 2>&1)
assert_matches "printf '%s' \"$first_output\"" 'go:github.com/roborev-dev/roborev/cmd/roborev@[0-9]+\.[0-9]+\.[0-9]+'

cat <<'EOF' >mise.toml
[settings]
install_before = "2026-04-07"

[tools]
'go:github.com/roborev-dev/roborev/cmd/roborev' = { version = "latest", install_before = "2100-01-01" }
EOF

assert_matches "mise install --dry-run 2>&1" "go:github.com/roborev-dev/roborev/cmd/roborev@[0-9]+\.[0-9]+\.[0-9]+"
assert_not_contains "mise install --dry-run 2>&1" "go:github.com/roborev-dev/roborev/cmd/roborev@0.50.0"
