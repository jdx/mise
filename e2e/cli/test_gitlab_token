#!/usr/bin/env bash

# Test mise gitlab token command

unset GITLAB_TOKEN MISE_GITLAB_TOKEN MISE_GITLAB_ENTERPRISE_TOKEN MISE_GITLAB_GLAB_CLI_TOKENS

# Test 1: No token configured
assert_contains "mise gitlab token" "(none)"

# Test 2: GITLAB_TOKEN env var
assert_contains "GITLAB_TOKEN=env-test-token mise gitlab token --unmask" "env-test-token"
assert_contains "GITLAB_TOKEN=env-test-token mise gitlab token --unmask" "GITLAB_TOKEN"

# Test 3: MISE_GITLAB_TOKEN takes precedence over GITLAB_TOKEN
assert_contains "MISE_GITLAB_TOKEN=mise-token GITLAB_TOKEN=other mise gitlab token --unmask" "mise-token"
assert_contains "MISE_GITLAB_TOKEN=mise-token GITLAB_TOKEN=other mise gitlab token --unmask" "MISE_GITLAB_TOKEN"

# Test 4: gitlab_tokens.toml
mkdir -p "$MISE_CONFIG_DIR"
cat >"$MISE_CONFIG_DIR/gitlab_tokens.toml" <<'EOF'
[tokens."gitlab.com"]
token = "toml-test-token"

[tokens."gitlab.example.com"]
token = "enterprise-toml-token"
EOF
assert_contains "mise gitlab token --unmask" "toml-test-token"
assert_contains "mise gitlab token --unmask" "gitlab_tokens.toml"
assert_contains "mise gitlab token gitlab.example.com --unmask" "enterprise-toml-token"

# Test 5: Env var beats toml file
assert_contains "GITLAB_TOKEN=env-wins mise gitlab token --unmask" "env-wins"
assert_not_contains "GITLAB_TOKEN=env-wins mise gitlab token --unmask" "toml-test-token"

# Test 6: glab CLI config fallback
rm "$MISE_CONFIG_DIR/gitlab_tokens.toml"
mkdir -p "$HOME/.config/glab-cli"
cat >"$HOME/.config/glab-cli/config.yml" <<'EOF'
hosts:
  gitlab.com:
    token: glab-cli-token
EOF
assert_contains "mise gitlab token --unmask" "glab-cli-token"
assert_contains "mise gitlab token --unmask" "glab CLI"

# Test 7: glab CLI can be disabled
assert_contains "MISE_GITLAB_GLAB_CLI_TOKENS=false mise gitlab token" "(none)"

# Test 8: Token masking
assert_not_contains "GITLAB_TOKEN=glpatabcdefghijklmnop mise gitlab token" "glpatabcdefghijklmnop"
assert_contains "GITLAB_TOKEN=glpatabcdefghijklmnop mise gitlab token" "glpa"

# Test 9: Enterprise env var for non-gitlab.com host
assert_contains "MISE_GITLAB_ENTERPRISE_TOKEN=ent-token mise gitlab token gitlab.example.com --unmask" "ent-token"
assert_contains "MISE_GITLAB_ENTERPRISE_TOKEN=ent-token mise gitlab token gitlab.example.com --unmask" "MISE_GITLAB_ENTERPRISE_TOKEN"
