#!/usr/bin/env bash

# Regression test for https://github.com/jdx/mise/discussions/8041

cat <<'EOF' >mise.toml
[tools]
dummy = { version = "latest", postinstall = "mise run postinstall-task" }

run = "echo POSTINSTALL_TASK_RAN=yes"
EOF

rm -rf "$MISE_DATA_DIR/installs/dummy"

output=$(mise install dummy 2>&1)

if [[ $output != *"POSTINSTALL_TASK_RAN"* ]]; then
	echo "postinstall task did not run"
	echo "Output: $output"
	exit 1
fi

if [[ $output == *"tool@"* ]]; then
	echo "MISE_TOOL_VERSION leaked into nested mise run"
	echo "Output: $output"
	exit 1
fi
